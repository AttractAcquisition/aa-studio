# Only VITE_* variables are exposed to the browser.
# Copy this file to .env for local development, then fill in your own values.

# Frontend / Vite
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_AA_CLIENT_ID=your-aa-client-id

# Optional, defaults to /api/content-factory
VITE_CONTENT_FACTORY_WEBHOOK_URL=/api/content-factory

# Server / local automation
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_IMAGE_MODEL=gpt-image-1
PORT=3001
RENDERER_URL=https://your-renderer.example.com
RENDER_SECRET=your-render-secret
LOVABLE_API_KEY=your-lovable-api-key
